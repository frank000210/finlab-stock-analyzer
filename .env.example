# FinLab Stock Analyzer - Environment Variables
# Copy this to .env and fill in your tokens

FINMIND_TOKEN=your_finmind_token_here
LINE_NOTIFY_TOKEN=your_line_notify_token_here
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin / OAuth
# ADMIN_SECRET signs admin session JWTs. If left unset, the backend
# generates a random per-process secret and logs a warning (safe fallback,
# but admin sessions won't survive a restart) -- set a real value for any
# deployment that needs persistent admin logins.
ADMIN_SECRET=
GOOGLE_CLIENT_ID=
# Comma-separated fallback admin whitelist (used until the DB-backed
# allowed_admin_emails setting has a value).
ALLOWED_ADMIN_EMAILS=frank210@gmail.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MONGODB_URI=mongodb://localhost:27017
