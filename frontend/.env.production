# Loaded by `vite build` (mode=production) -- this is what the Docker image and
# Zeabur use. The built SPA is served by the FastAPI backend from the SAME
# origin (same host+port), so the API base must be empty (relative URLs).
# This makes the app work on any port locally (Docker 8000/8080) and on
# whatever host Zeabur assigns, with no code changes.
VITE_API_BASE=
