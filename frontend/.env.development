# Loaded by `vite dev` (mode=development).
# Frontend dev server runs on :5173 and the backend runs separately on :8000.
# vite.config.js already proxies /api and /ws to http://localhost:8000, so an
# empty base (same-origin -> proxied) works. Set an explicit URL here only if
# you run the backend somewhere the proxy does not cover.
VITE_API_BASE=
